# Переменные окружения (скопируйте в `.env.local`)

# URL проекта (публично, для сборки и подсказок в UI)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Секретный ключ API (только сервер: Server Actions, RSC). Не добавляйте в клиентский код.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Секрет для подписи сессионной cookie (JWT). Случайная строка ≥16 символов.
SESSION_SECRET=замените_на_длинную_случайную_строку
